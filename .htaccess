# Configuration O2switch / LiteSpeed Passenger
# Ce fichier a été optimisé par l'audit technique pour résoudre l'Erreur 500

<IfModule mod_passenger.c>
    PassengerEnabled on
    # À adapter selon votre dossier cPanel (ex: /home/votre-user/logertg.com)
    PassengerAppRoot /home/votre-user/votre-dossier-togo
    PassengerAppType wsgi
    PassengerStartupFile passenger_wsgi.py
    PassengerPython /home/votre-user/virtualenv/votre-dossier-togo/3.11/bin/python
    PassengerBaseURI /
</IfModule>

# Forcer le bon handler pour passenger_wsgi.py (Evite la fuite de code source)
<Files "passenger_wsgi.py">
    SetHandler application/x-httpd-wsgi
</Files>

# Redirection SEO : logertogo.com -> logertg.com (ou vice-versa selon votre choix)
RewriteEngine On
RewriteBase /
RewriteCond %{HTTP_HOST} ^logertogo\.com$ [NC,OR]
RewriteCond %{HTTP_HOST} ^www\.logertogo\.com$ [NC]
RewriteRule ^(.*)$ https://logertg.com/$1 [R=301,L]

# Forcer HTTPS (Sécurité SSL)
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Routage des requêtes vers le moteur Django
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !^/static/
RewriteCond %{REQUEST_URI} !^/media/
RewriteRule ^(.*)$ passenger_wsgi.py [QSA,L]

# Sécurisation : Empêcher l'accès direct aux fichiers sensibles
<FilesMatch "\.(py|pyc|sql|sqlite3|env|log)$">
    Order deny,allow
    Deny from all
</FilesMatch>
